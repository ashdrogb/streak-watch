# Leave unset for local dev -- api.js falls back to the relative "/api"
# path, which vite.config.js proxies to Flask on http://localhost:5000.
#
# Set this in Vercel's Project -> Settings -> Environment Variables once
# the backend is deployed, e.g.:
# VITE_API_URL=https://football-streaks-api.vercel.app/api
VITE_API_URL=
