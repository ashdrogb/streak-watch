# Copy this file to .env for local development.
# In production (Vercel), set these as Project -> Settings -> Environment
# Variables instead -- .env is not deployed.

# Required for PL / PD / BL1 / SA / FL1, and optionally BL2 / EL1 / EL2 / SD / FL2
# if you're on a paid football-data.org plan that includes them.
# Get a free key at https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# Optional. Powers the fallback for EL1 / EL2 / SD / FL2 (and BL2 if you
# don't want to rely on OpenLigaDB). Free plan: 100 requests/day.
# Get a free key at https://www.api-football.com/ -- use ONE of the next
# two, matching wherever you actually signed up:
API_FOOTBALL_KEY=

# If you got your key through RapidAPI's marketplace listing instead of
# directly at api-football.com, put it here, not above -- the two use
# different auth gateways and a RapidAPI key will NOT work as
# API_FOOTBALL_KEY (it'll fail with a 401/403). If both are set, this one
# takes priority.
RAPIDAPI_KEY=

# Lock CORS down once you know your deployed frontend's URL, e.g.
# https://football-streaks.vercel.app -- defaults to "*" (any origin).
FRONTEND_ORIGIN=*

# How long /api/streaks caches a full league scan, in seconds. Keep this
# >= ~1800 (30 min) on the free plans: EL1/EL2/SD/FL2 try API-Football
# first, and its free tier is capped at 100 requests/day total -- at the
# default below (3 hours = ~8 scans/day) that's ~32 calls/day, well under
# the cap. Going lower trades a fresher dashboard for burning that quota
# faster.
CACHE_TTL_SECONDS=10800
